PORT=3000
HOST=0.0.0.0
JWT_SECRET=change-me-to-a-long-random-string-in-production
DATA_DIR=./data
BASE_URL=http://localhost:3000

# HTTPS — auto-generates a self-signed cert by default (browser will warn).
# For a trusted cert, install mkcert:
#   brew install mkcert && mkcert -install && mkcert localhost
# Then set:
#   SSL_CERT=./localhost.pem
#   SSL_KEY=./localhost-key.pem
HTTPS_PORT=3001
# SSL_CERT=
# SSL_KEY=
