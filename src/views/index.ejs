<%- include('_head', { title: 'Git hosting, stripped to the essentials' }) %>

<main>
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <h1 class="hero-title">
          Git hosting,<br>
          <span class="accent">stripped to the essentials.</span>
        </h1>
        <p class="hero-sub">No CI/CD. No Marketplace. No AI. Just repositories, issues, and pull requests — done right.</p>
        <div class="hero-cta">
          <a href="/register" class="btn btn-accent btn-lg">Get started free</a>
          <a href="/explore" class="btn btn-ghost btn-lg">Explore repos</a>
        </div>
      </div>
      <div class="hero-art">
        <svg viewBox="0 0 340 240" xmlns="http://www.w3.org/2000/svg" class="hero-diagram">
          <!-- Terminal window -->
          <rect x="20" y="20" width="300" height="200" rx="8" fill="#1a1a2e" stroke="#2d2d4e" stroke-width="1.5"/>
          <rect x="20" y="20" width="300" height="28" rx="8" fill="#252540"/>
          <rect x="20" y="36" width="300" height="12" fill="#252540"/>
          <circle cx="38" cy="34" r="5" fill="#ff5f57"/>
          <circle cx="56" cy="34" r="5" fill="#febc2e"/>
          <circle cx="74" cy="34" r="5" fill="#28c840"/>
          <text x="36" y="66" font-family="monospace" font-size="11" fill="#4ec9b0">$</text>
          <text x="48" y="66" font-family="monospace" font-size="11" fill="#cdd9e5">git push origin main</text>
          <text x="36" y="84" font-family="monospace" font-size="10" fill="#6e7681">Enumerating objects: 5, done.</text>
          <text x="36" y="98" font-family="monospace" font-size="10" fill="#6e7681">Counting objects: 100% (5/5), done.</text>
          <text x="36" y="112" font-family="monospace" font-size="10" fill="#e36d2f">To http://forgelite.dev/you/repo.git</text>
          <text x="36" y="126" font-family="monospace" font-size="10" fill="#3fb950">   abc1234..def5678  main -> main</text>
          <text x="36" y="150" font-family="monospace" font-size="11" fill="#4ec9b0">$</text>
          <text x="48" y="150" font-family="monospace" font-size="11" fill="#cdd9e5">git clone http://forgelite.dev/<wbr/>you/repo.git</text>
          <text x="36" y="168" font-family="monospace" font-size="10" fill="#6e7681">Cloning into 'repo'...</text>
          <text x="36" y="182" font-family="monospace" font-size="10" fill="#3fb950">done.</text>
          <rect x="36" y="196" width="8" height="12" fill="#e36d2f" opacity="0.9"/>
        </svg>
      </div>
    </div>
  </section>

  <section class="features">
    <div class="container">
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3h7v7H3zM14 3h7v7h-7zM3 14h7v7H3zM14 14h7v7h-7z"/></svg>
          </div>
          <h3>Repositories</h3>
          <p>Public and private repos. Fork, star, browse files, view commits. Git CLI works out of the box.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
          </div>
          <h3>Issues</h3>
          <p>Track bugs and feature requests. Open, comment, close. Markdown supported.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 3v12M6 15a3 3 0 100 6 3 3 0 000-6zM6 3a3 3 0 100-0 3 3 0 000 0zM18 6a3 3 0 100 6 3 3 0 000-6zM18 9H6"/><path d="M18 9v9M18 18a3 3 0 100 6 3 3 0 000-6z" stroke-dasharray="0"/></svg>
          </div>
          <h3>Pull Requests</h3>
          <p>Code review with real diffs. Merge branches, leave comments, track changes.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          </div>
          <h3>Web Hosting</h3>
          <p>Push to <code>gh-pages</code> branch and your site is live at <code>/pages</code>. Zero config.</p>
        </div>
      </div>
    </div>
  </section>

  <% if (recentRepos && recentRepos.length) { %>
  <section class="recent-section">
    <div class="container">
      <h2 class="section-title">Recent repositories</h2>
      <div class="repo-grid">
        <% recentRepos.forEach(repo => { %>
        <a href="/<%= repo.owner_name %>/<%= repo.name %>" class="repo-card-link">
          <div class="repo-card">
            <div class="repo-card-header">
              <div class="repo-name"><%= repo.owner_name %>/<strong><%= repo.name %></strong></div>
              <div class="repo-star-count">
                <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z"/></svg>
                <%= repo.star_count || 0 %>
              </div>
            </div>
            <% if (repo.description) { %><p class="repo-card-desc"><%= repo.description %></p><% } %>
            <div class="repo-card-meta"><%= timeAgo(repo.updated_at) %></div>
          </div>
        </a>
        <% }) %>
      </div>
    </div>
  </section>
  <% } %>
</main>

<%- include('_foot') %>
