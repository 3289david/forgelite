<%- include('_head', { title: 'Git hosting, stripped to the essentials' }) %>

<main>
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <h1 class="hero-title">
          Git hosting,<br>
          <span class="accent">stripped to the essentials.</span>
        </h1>
        <p class="hero-sub">No CI/CD. No Marketplace. No AI. Just repositories, issues, and pull requests — done right.</p>
        <div class="hero-cta">
          <a href="/register" class="btn btn-accent btn-lg">Get started free</a>
          <a href="/explore" class="btn btn-ghost btn-lg">Explore repos</a>
        </div>
      </div>
      <div class="hero-art">
        <!-- Terminal: viewBox sized to fit all text comfortably -->
        <svg viewBox="0 0 460 290" xmlns="http://www.w3.org/2000/svg" class="hero-diagram">
          <!-- Window chrome -->
          <rect x="0" y="0" width="460" height="290" rx="10" fill="#0d1117"/>
          <rect x="0" y="0" width="460" height="36" rx="10" fill="#161b22"/>
          <rect x="0" y="26" width="460" height="10" fill="#161b22"/>
          <circle cx="18" cy="18" r="5.5" fill="#ff5f57"/>
          <circle cx="36" cy="18" r="5.5" fill="#febc2e"/>
          <circle cx="54" cy="18" r="5.5" fill="#28c840"/>
          <text x="200" y="22" font-family="monospace" font-size="11" fill="#484f58" text-anchor="middle">bash</text>

          <!-- Command 1: git push -->
          <text x="14" y="62" font-family="monospace" font-size="12" fill="#58a6ff">$</text>
          <text x="28" y="62" font-family="monospace" font-size="12" fill="#e6edf3">git push origin main</text>

          <text x="14" y="80" font-family="monospace" font-size="10.5" fill="#484f58">Enumerating objects: 5, done.</text>
          <text x="14" y="95" font-family="monospace" font-size="10.5" fill="#484f58">Counting objects: 100% (5/5), done.</text>
          <text x="14" y="110" font-family="monospace" font-size="10.5" fill="#e36d2f">To http://forgelite.dev/you/repo.git</text>
          <text x="14" y="125" font-family="monospace" font-size="10.5" fill="#3fb950">   abc1234..def5678  main -&gt; main</text>

          <!-- Divider -->
          <line x1="14" y1="143" x2="446" y2="143" stroke="#21262d" stroke-width="1"/>

          <!-- Command 2: git clone -->
          <text x="14" y="163" font-family="monospace" font-size="12" fill="#58a6ff">$</text>
          <text x="28" y="163" font-family="monospace" font-size="12" fill="#e6edf3">git clone http://forgelite.dev/</text>
          <text x="28" y="179" font-family="monospace" font-size="12" fill="#e6edf3">      you/repo.git</text>

          <text x="14" y="199" font-family="monospace" font-size="10.5" fill="#484f58">Cloning into 'repo'...</text>
          <text x="14" y="215" font-family="monospace" font-size="10.5" fill="#3fb950">remote: Counting objects: 5, done.</text>
          <text x="14" y="230" font-family="monospace" font-size="10.5" fill="#3fb950">Receiving objects: 100% (5/5), done.</text>

          <!-- Prompt with cursor -->
          <text x="14" y="257" font-family="monospace" font-size="12" fill="#58a6ff">$</text>
          <rect x="28" y="245" width="8" height="15" fill="#e36d2f" rx="1"/>
        </svg>
      </div>
    </div>
  </section>

  <section class="features">
    <div class="container">
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3h7v7H3zM14 3h7v7h-7zM3 14h7v7H3zM14 14h7v7h-7z"/></svg>
          </div>
          <h3>Repositories</h3>
          <p>Public and private repos. Fork, star, browse files, view commits. Git CLI works out of the box.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
          </div>
          <h3>Issues</h3>
          <p>Track bugs and feature requests. Open, comment, close. Markdown supported.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 3v12M6 15a3 3 0 100 6 3 3 0 000-6zM6 3a3 3 0 100-0 3 3 0 000 0zM18 6a3 3 0 100 6 3 3 0 000-6zM18 9H6"/><path d="M18 9v9M18 18a3 3 0 100 6 3 3 0 000-6z" stroke-dasharray="0"/></svg>
          </div>
          <h3>Pull Requests</h3>
          <p>Code review with real diffs. Merge branches, leave comments, track changes.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          </div>
          <h3>Web Hosting</h3>
          <p>Push to <code>gh-pages</code> branch and your site is live at <code>/pages</code>. Zero config.</p>
        </div>
      </div>
    </div>
  </section>

  <% if (recentRepos && recentRepos.length) { %>
  <section class="recent-section">
    <div class="container">
      <h2 class="section-title">Recent repositories</h2>
      <div class="repo-grid">
        <% recentRepos.forEach(repo => { %>
        <a href="/<%= repo.owner_name %>/<%= repo.name %>" class="repo-card-link">
          <div class="repo-card">
            <div class="repo-card-header">
              <div class="repo-name"><%= repo.owner_name %>/<strong><%= repo.name %></strong></div>
              <div class="repo-star-count">
                <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z"/></svg>
                <%= repo.star_count || 0 %>
              </div>
            </div>
            <% if (repo.description) { %><p class="repo-card-desc"><%= repo.description %></p><% } %>
            <div class="repo-card-meta"><%= timeAgo(repo.updated_at) %></div>
          </div>
        </a>
        <% }) %>
      </div>
    </div>
  </section>
  <% } %>
</main>

<%- include('_foot') %>
