<%- include('_head', { title: 'New repository' }) %>
<main class="form-page">
<div class="form-page-inner">
  <h1 style="margin-bottom:24px">Create a new repository</h1>
  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
  <form method="POST" action="/new" class="form-card">
    <div class="form-group">
      <label for="name">Repository name <span class="required">*</span></label>
      <input type="text" id="name" name="name" class="form-input" pattern="[a-zA-Z0-9_.\-]{1,100}" required autofocus>
      <span class="form-hint">Letters, numbers, hyphens, underscores, dots.</span>
    </div>
    <div class="form-group">
      <label for="description">Description</label>
      <input type="text" id="description" name="description" class="form-input" maxlength="255">
    </div>
    <div class="form-group">
      <label for="website">Website</label>
      <input type="url" id="website" name="website" class="form-input" placeholder="https://...">
    </div>
    <div class="form-group">
      <label class="checkbox-label">
        <input type="checkbox" name="is_private">
        Make this repository private
      </label>
    </div>
    <button type="submit" class="btn btn-accent">Create repository</button>
  </form>
</div>
</main>
<%- include('_foot') %>
