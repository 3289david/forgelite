<%- include('_head', { title: 'Explore' }) %>
<main class="container explore-page">
  <div class="explore-header">
    <h1>Explore repositories</h1>
    <p>Public repositories on this ForgeLite instance.</p>
  </div>

  <% if (repos.length === 0) { %>
  <div class="empty-state" style="border:1px solid var(--border);border-radius:var(--radius)">
    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3h7v7H3zM14 3h7v7h-7zM3 14h7v7H3zM14 14h7v7h-7z"/></svg>
    <p>No public repositories yet.</p>
    <% if (user) { %><a href="/new" class="btn btn-accent btn-sm">Create the first one</a><% } else { %><a href="/register" class="btn btn-accent btn-sm">Register to get started</a><% } %>
  </div>
  <% } else { %>
  <div class="repo-list">
    <% repos.forEach(repo => { %>
    <div class="repo-item">
      <div class="repo-item-header">
        <a href="/<%= repo.owner_name %>/<%= repo.name %>" class="repo-item-name">
          <a href="/<%= repo.owner_name %>" class="repo-owner-link"><%= repo.owner_name %></a>/<strong><%= repo.name %></strong>
        </a>
        <span class="repo-visibility-badge public">Public</span>
      </div>
      <% if (repo.description) { %><p class="repo-item-desc"><%= repo.description %></p><% } %>
      <div class="repo-item-meta">
        <% if (repo.star_count > 0) { %>
        <span class="repo-meta-stat">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z"/></svg>
          <%= repo.star_count %>
        </span>
        <% } %>
        <span>Updated <%= timeAgo(repo.updated_at) %></span>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</main>
<%- include('_foot') %>
