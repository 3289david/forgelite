<div class="repo-header">
  <div class="repo-breadcrumb">
    <a href="/<%= owner %>" class="repo-owner"><%= owner %></a>
    <span class="repo-sep">/</span>
    <a href="/<%= owner %>/<%= repoName %>" class="repo-name-link"><strong><%= repoName %></strong></a>
    <span class="repo-visibility-badge <%= repoRow.is_private ? 'private' : 'public' %>"><%= repoRow.is_private ? 'Private' : 'Public' %></span>
    <% if (typeof forkSource !== 'undefined' && forkSource) { %>
    <span class="fork-badge">forked from <a href="/<%= forkSource.owner_name %>/<%= forkSource.name %>"><%= forkSource.owner_name %>/<%= forkSource.name %></a></span>
    <% } %>
  </div>
  <div class="repo-actions">
    <% if (user && user.username !== owner) { %>
    <form method="POST" action="/<%= owner %>/<%= repoName %>/fork" class="inline-form">
      <button type="submit" class="btn btn-sm btn-ghost">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75v-.878a2.25 2.25 0 111.5 0v.878a2.25 2.25 0 01-2.25 2.25h-1.5v2.128a2.251 2.251 0 11-1.5 0V8.5h-1.5A2.25 2.25 0 013 6.25v-.878a2.25 2.25 0 111.5 0zM5 3.25a.75.75 0 10-1.5 0 .75.75 0 001.5 0zm6.75.75a.75.75 0 100-1.5.75.75 0 000 1.5zm-3 8.75a.75.75 0 10-1.5 0 .75.75 0 001.5 0z"/></svg>
        Fork <span class="stat-count"><%= typeof forksCount !== 'undefined' ? forksCount : 0 %></span>
      </button>
    </form>
    <% } %>
    <% if (user) { %>
    <button class="btn btn-sm btn-ghost" id="star-btn" data-owner="<%= owner %>" data-repo="<%= repoName %>" data-starred="<%= typeof starred !== 'undefined' && starred ? '1' : '0' %>">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z"/></svg>
      <span id="star-label"><%= typeof starred !== 'undefined' && starred ? 'Starred' : 'Star' %></span>
      <span class="stat-count" id="star-count"><%= typeof starCount !== 'undefined' ? starCount : 0 %></span>
    </button>
    <% } %>
  </div>
</div>
<% if (repoRow.description) { %><p class="repo-description"><%= repoRow.description %></p><% } %>
