<%- include('../_head', { title: filePath + ' — ' + owner + '/' + repoName }) %>
<main class="repo-page">
  <%- include('./_repo-header') %>
  <%- include('./_repo-tabs', { active: 'code' }) %>
  <div class="repo-body">
    <div class="file-path-bar">
      <a href="/<%= owner %>/<%= repoName %>"><%= repoName %></a>
      <% breadcrumbs.forEach((bc, i) => { %>
        <span class="path-sep">/</span>
        <% if (i < breadcrumbs.length - 1) { %>
        <a href="/<%= owner %>/<%= repoName %>/tree/<%= branch %>/<%= bc.path %>"><%= bc.name %></a>
        <% } else { %>
        <strong><%= bc.name %></strong>
        <% } %>
      <% }) %>
    </div>

    <% if (fileCommit) { %>
    <div class="file-meta-bar">
      <div class="commit-author-avatar"><%= fileCommit.author.slice(0,1).toUpperCase() %></div>
      <span class="commit-author"><%= fileCommit.author %></span>
      <span class="commit-msg"><%= fileCommit.message %></span>
      <code class="commit-hash"><%= fileCommit.shortHash %></code>
      <span class="commit-date"><%= timeAgo(fileCommit.date) %></span>
    </div>
    <% } %>

    <div class="file-viewer">
      <div class="file-viewer-header">
        <span class="file-line-count"><%= lineCount %> lines</span>
        <% if (user && user.id === repoRow.owner_id && !isBinary) { %>
        <div class="file-viewer-actions">
          <a href="/<%= owner %>/<%= repoName %>/edit/<%= branch %>/<%= filePath %>" class="btn btn-sm btn-ghost">
            <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor"><path d="M11.013 1.427a1.75 1.75 0 012.474 0l1.086 1.086a1.75 1.75 0 010 2.474l-8.61 8.61c-.21.21-.47.364-.756.445l-3.251.93a.75.75 0 01-.927-.928l.929-3.25c.081-.286.235-.547.445-.758l8.61-8.61zm1.414 1.06a.25.25 0 00-.354 0L10.811 3.75l1.439 1.44 1.263-1.263a.25.25 0 000-.354l-1.086-1.086zM11.189 6.25L9.75 4.81l-6.286 6.287a.25.25 0 00-.064.108l-.558 1.953 1.953-.558a.25.25 0 00.108-.064L11.19 6.25z"/></svg>
            Edit
          </a>
          <form method="POST" action="/<%= owner %>/<%= repoName %>/delete-file/<%= branch %>/<%= filePath %>" style="display:inline" onsubmit="return confirm('Delete <%= filePath %>? This cannot be undone.')">
            <input type="hidden" name="commit_message" value="Delete <%= filePath %>">
            <button type="submit" class="btn btn-sm btn-ghost" style="color:var(--danger);border-color:var(--danger)">
              <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor"><path d="M11 1.75V3h2.25a.75.75 0 010 1.5H2.75a.75.75 0 010-1.5H5V1.75C5 .784 5.784 0 6.75 0h2.5C10.216 0 11 .784 11 1.75zM4.496 6.675l.66 6.6a.25.25 0 00.249.225h5.19a.25.25 0 00.249-.225l.66-6.6a.75.75 0 011.492.149l-.66 6.6A1.748 1.748 0 0110.595 15h-5.19a1.75 1.75 0 01-1.741-1.575l-.66-6.6a.75.75 0 111.492-.15zM6.5 1.75V3h3V1.75a.25.25 0 00-.25-.25h-2.5a.25.25 0 00-.25.25z"/></svg>
              Delete
            </button>
          </form>
        </div>
        <% } %>
      </div>
      <% if (isBinary) { %>
        <% if (content.startsWith('data:image/')) { %>
        <div class="file-binary-img"><img src="<%= content %>" alt="<%= filePath %>"></div>
        <% } else { %>
        <div class="file-binary">Binary file · cannot display</div>
        <% } %>
      <% } else { %>
      <div class="file-code">
        <table class="code-table">
          <tbody>
          <% const lines = content.split('\n'); const hlines = highlighted.split('\n'); %>
          <% lines.forEach((_, i) => { %>
          <tr>
            <td class="line-num"><%= i + 1 %></td>
            <td class="line-code"><%- hlines[i] || '' %></td>
          </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>
</main>
<%- include('../_foot') %>
