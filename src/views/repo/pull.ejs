<%- include('../_head', { title: '#' + pr.number + ' ' + pr.title }) %>
<main class="repo-page">
  <%- include('./_repo-header') %>
  <%- include('./_repo-tabs', { active: 'pulls' }) %>
  <div class="repo-body">
    <div class="issue-page-header">
      <h1 class="issue-page-title">
        <%= pr.title %>
        <span class="issue-number">#<%= pr.number %></span>
      </h1>
      <div class="issue-page-meta">
        <span class="status-badge status-<%= pr.status %>">
          <% if (pr.status === 'open') { %>
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M7.177 3.073L9.573.677A.25.25 0 0110 .854v4.792a.25.25 0 01-.427.177L7.177 3.427a.25.25 0 010-.354zM3.75 2.5a.75.75 0 100 1.5.75.75 0 000-1.5zm-2.25.75a2.25 2.25 0 113 2.122v5.256a2.251 2.251 0 11-1.5 0V5.372A2.25 2.25 0 011.5 3.25zM11 2.5h-1V4h1a1 1 0 011 1v5.628a2.251 2.251 0 101.5 0V5A2.5 2.5 0 0011 2.5zm1 10.25a.75.75 0 111.5 0 .75.75 0 01-1.5 0zM3.75 12a.75.75 0 100 1.5.75.75 0 000-1.5z"/></svg>
          Open
          <% } else if (pr.status === 'merged') { %>
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M5.45 5.154A4.25 4.25 0 019.25 7h1.378a2.251 2.251 0 110 1.5H9.25A5.75 5.75 0 015.75 10.607a3.75 3.75 0 10-1.5.148V5.254a3.75 3.75 0 101.2-.1zM4.25 13.5a2.25 2.25 0 110-4.5 2.25 2.25 0 010 4.5zm8.5-4.5a.75.75 0 110 1.5.75.75 0 010-1.5zM5.5 3.25a2.25 2.25 0 10-4.5 0 2.25 2.25 0 004.5 0z"/></svg>
          Merged
          <% } else { %>
          Closed
          <% } %>
        </span>
        <code class="branch-pill"><%= pr.head_branch %></code>
        <span>→</span>
        <code class="branch-pill"><%= pr.base_branch %></code>
        · by <a href="/<%= pr.author_name %>"><%= pr.author_name %></a> · <%= timeAgo(pr.created_at) %>
      </div>
    </div>

    <div class="discussion">
      <div class="comment-block is-op">
        <div class="comment-avatar"><%= pr.author_name.slice(0,1).toUpperCase() %></div>
        <div class="comment-body">
          <div class="comment-header">
            <strong><%= pr.author_name %></strong>
            <span class="comment-date"><%= timeAgo(pr.created_at) %></span>
          </div>
          <div class="comment-content markdown-body"><%- renderMarkdown(pr.body || '') %></div>
        </div>
      </div>

      <% if (pr.status === 'open') { %>
      <div class="merge-box">
        <div class="merge-stats">
          <span class="add-stat">+<%= diffStats.additions %></span>
          <span class="del-stat"> -<%= diffStats.deletions %></span>
          <span class="files-stat"><%= diffStats.files %> file<%= diffStats.files !== 1 ? 's' : '' %> changed</span>
        </div>
        <% if (isOwner) { %>
        <form method="POST" action="/<%= owner %>/<%= repoName %>/pulls/<%= pr.number %>/merge">
          <button type="submit" class="btn btn-accent btn-sm" onclick="return confirm('Merge <%= pr.head_branch %> into <%= pr.base_branch %>?')">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M5.45 5.154A4.25 4.25 0 019.25 7h1.378a2.251 2.251 0 110 1.5H9.25A5.75 5.75 0 015.75 10.607a3.75 3.75 0 10-1.5.148V5.254a3.75 3.75 0 101.2-.1zM4.25 13.5a2.25 2.25 0 110-4.5 2.25 2.25 0 010 4.5zm8.5-4.5a.75.75 0 110 1.5.75.75 0 010-1.5zM5.5 3.25a2.25 2.25 0 10-4.5 0 2.25 2.25 0 004.5 0z"/></svg>
            Merge pull request
          </button>
        </form>
        <% } %>
        <% if (isOwner || isAuthor) { %>
        <form method="POST" action="/<%= owner %>/<%= repoName %>/pulls/<%= pr.number %>/close">
          <button type="submit" class="btn btn-ghost btn-sm">Close pull request</button>
        </form>
        <% } %>
      </div>
      <% } %>

      <% if (diffHtml) { %>
      <div class="diff-section">
        <h3 class="diff-section-title">Changes</h3>
        <div class="diff-container"><%- diffHtml %></div>
      </div>
      <% } %>

      <% comments.forEach(c => { %>
      <div class="comment-block">
        <div class="comment-avatar"><%= c.author_name.slice(0,1).toUpperCase() %></div>
        <div class="comment-body">
          <div class="comment-header">
            <strong><%= c.author_name %></strong>
            <span class="comment-date"><%= timeAgo(c.created_at) %></span>
          </div>
          <div class="comment-content markdown-body"><%- renderMarkdown(c.body) %></div>
        </div>
      </div>
      <% }) %>

      <% if (user) { %>
      <div class="new-comment-form">
        <div class="comment-avatar"><%= user.username.slice(0,1).toUpperCase() %></div>
        <div class="new-comment-body">
          <form method="POST" action="/<%= owner %>/<%= repoName %>/pulls/<%= pr.number %>/comment">
            <textarea name="body" class="form-input" rows="5" placeholder="Leave a comment... (Markdown supported)"></textarea>
            <div class="comment-form-actions">
              <button type="submit" class="btn btn-accent btn-sm">Comment</button>
            </div>
          </form>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</main>
<%- include('../_foot') %>
