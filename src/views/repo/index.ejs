<%- include('../_head', { title: owner + '/' + repoName }) %>
<main class="repo-page">

  <%- include('./_repo-header') %>

  <%- include('./_repo-tabs', { active: 'code' }) %>

  <div class="repo-body">
    <% if (empty) { %>
    <div class="empty-repo">
      <h3>Get started</h3>
      <% if (user && user.id === repoRow.owner_id) { %>
      <div style="display:flex;gap:12px;margin-bottom:20px">
        <a href="/<%= owner %>/<%= repoName %>/new-file/main" class="btn btn-accent">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M7.75 2a.75.75 0 01.75.75V7h4.25a.75.75 0 010 1.5H8.5v4.25a.75.75 0 01-1.5 0V8.5H2.75a.75.75 0 010-1.5H7V2.75A.75.75 0 017.75 2z"/></svg>
          Create a file in the browser
        </a>
      </div>
      <p style="color:var(--text-muted);margin-bottom:8px">Or push from the command line:</p>
      <% } else { %>
      <p>Push your first commit to this repository:</p>
      <% } %>
      <%
        const cloneUrlWithUser = user
          ? cloneUrl.replace('http://', `http://${user.username}@`)
          : cloneUrl;
      %>
      <pre class="clone-instructions">git clone <%= cloneUrlWithUser %>
cd <%= repoName %>
echo "# <%= repoName %>" >> README.md
git add README.md
git commit -m "Initial commit"
git push origin main</pre>
      <% if (user) { %>
      <details class="clone-trouble" style="margin-top:12px">
        <summary>Authentication failed?</summary>
        <div class="clone-trouble-body">
          <p>Clear cached credentials and retry:</p>
          <pre>git credential reject &lt;&lt;EOF
protocol=http
host=<%= cloneUrl.replace(/^https?:\/\//, '').split('/')[0] %>
EOF</pre>
          <p>Or embed credentials directly:</p>
          <pre>git remote set-url origin http://<%= user.username %>:YOUR_PASSWORD@<%= cloneUrl.replace(/^https?:\/\//, '') %></pre>
        </div>
      </details>
      <% } %>
    </div>
    <% } else { %>

    <div class="repo-main-content">
      <div class="repo-file-area">
        <!-- Branch + Clone bar -->
        <div class="file-area-toolbar">
          <div class="branch-selector">
            <select class="branch-select" onchange="location.href='/<%= owner %>/<%= repoName %>?branch='+this.value">
              <% branches.forEach(b => { %>
              <option value="<%= b %>" <%= b === currentBranch ? 'selected' : '' %>><%= b %></option>
              <% }) %>
            </select>
          </div>
          <div class="toolbar-actions">
            <% if (user && user.id === repoRow.owner_id) { %>
            <a href="/<%= owner %>/<%= repoName %>/new-file/<%= currentBranch %>" class="btn btn-sm btn-ghost">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M7.75 2a.75.75 0 01.75.75V7h4.25a.75.75 0 010 1.5H8.5v4.25a.75.75 0 01-1.5 0V8.5H2.75a.75.75 0 010-1.5H7V2.75A.75.75 0 017.75 2z"/></svg>
              New file
            </a>
            <% } %>
            <% if (commits && commits.length) { %>
            <a href="/<%= owner %>/<%= repoName %>/commits/<%= currentBranch %>" class="btn btn-sm btn-ghost">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M1.643 3.143L.427 1.927A.25.25 0 000 2.104V5.75c0 .138.112.25.25.25h3.646a.25.25 0 00.177-.427L2.715 4.215a6.5 6.5 0 11-1.18 4.458.75.75 0 10-1.493.154 8.001 8.001 0 101.6-5.684zM7.75 4a.75.75 0 01.75.75v2.992l2.028.812a.75.75 0 01-.557 1.392l-2.5-1A.75.75 0 017 8.25v-3.5A.75.75 0 017.75 4z"/></svg>
              <%= commits[0].shortHash %>
            </a>
            <% } %>
            <div class="clone-dropdown">
              <button class="btn btn-sm btn-accent" id="clone-btn">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M5.75 1a.75.75 0 00-.75.75v3c0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75v-3a.75.75 0 00-.75-.75h-4.5zm.75 3V2.5h3V4h-3zm-2.874-.467a.75.75 0 00-.752-1.298A5.001 5.001 0 002.5 8H1.75a.75.75 0 000 1.5h9.5a.75.75 0 000-1.5H10A5.001 5.001 0 006.25 3.5h-.624z"/></svg>
                Clone
              </button>
              <div class="clone-popup" id="clone-popup">
                <p class="clone-label">Clone via HTTPS</p>
                <%
                  // Include username in URL so git uses the right credentials
                  const cloneUrlAuth = user
                    ? cloneUrl.replace('http://', `http://${user.username}@`)
                    : cloneUrl;
                %>
                <div class="clone-url-row">
                  <input type="text" class="clone-url-input" value="<%= cloneUrlAuth %>" readonly id="clone-url-input">
                  <button class="btn btn-sm btn-ghost" onclick="copyCloneUrl()">Copy</button>
                </div>
                <div class="clone-hint">
                  <% if (user) { %>
                  <p>Use your ForgeLite password. Or generate a <a href="/<%= owner %>/<%= repoName %>/settings#tokens">Personal Access Token</a>.</p>
                  <details class="clone-trouble">
                    <summary>Authentication failed?</summary>
                    <div class="clone-trouble-body">
                      <p>Clear cached credentials for this server, then retry:</p>
                      <pre>git credential reject &lt;&lt;EOF
protocol=http
host=<%= cloneUrl.replace(/^https?:\/\//, '').split('/')[0] %>
EOF</pre>
                      <p>Or set credentials directly in the remote URL:</p>
                      <pre>git remote set-url origin http://<%= user.username %>:PASSWORD@<%= cloneUrl.replace(/^https?:\/\//, '') %></pre>
                    </div>
                  </details>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Latest commit bar -->
        <% if (commits && commits.length > 0) { %>
        <div class="latest-commit-bar">
          <div class="commit-author-avatar"><%= commits[0].author.slice(0,1).toUpperCase() %></div>
          <div class="commit-info">
            <span class="commit-author"><%= commits[0].author %></span>
            <span class="commit-msg"><%= commits[0].message %></span>
          </div>
          <div class="commit-meta">
            <code class="commit-hash"><%= commits[0].shortHash %></code>
            <span class="commit-date"><%= timeAgo(commits[0].date) %></span>
          </div>
        </div>
        <% } %>

        <!-- File tree -->
        <div class="file-tree">
          <% if (tree.length === 0) { %>
          <div class="file-tree-empty">Empty directory</div>
          <% } %>
          <% tree.filter(e => e.type === 'tree').forEach(entry => { %>
          <div class="file-tree-row">
            <div class="file-tree-name">
              <svg class="file-icon folder-icon" width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M1.75 1A1.75 1.75 0 000 2.75v10.5C0 14.216.784 15 1.75 15h12.5A1.75 1.75 0 0016 13.25v-8.5A1.75 1.75 0 0014.25 3H7.5a.25.25 0 01-.2-.1l-.9-1.2c-.33-.44-.85-.7-1.4-.7h-3.25z"/></svg>
              <a href="/<%= owner %>/<%= repoName %>/tree/<%= currentBranch %>/<%= entry.name %>"><%= entry.name %></a>
            </div>
            <div class="file-tree-commit">
              <% const lc = lastCommits[entry.name]; if (lc) { %>
              <span class="file-tree-commit-msg"><%= lc.message.slice(0, 52) %><%= lc.message.length > 52 ? '…' : '' %></span>
              <span class="file-tree-commit-date"><%= timeAgo(lc.date) %></span>
              <% } %>
            </div>
          </div>
          <% }) %>
          <% tree.filter(e => e.type === 'blob').forEach(entry => { %>
          <div class="file-tree-row">
            <div class="file-tree-name">
              <svg class="file-icon" width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M2 1.75C2 .784 2.784 0 3.75 0h6.586c.464 0 .909.184 1.237.513l2.914 2.914c.329.328.513.773.513 1.237v9.586A1.75 1.75 0 0113.25 16h-9.5A1.75 1.75 0 012 14.25V1.75zm1.75-.25a.25.25 0 00-.25.25v12.5c0 .138.112.25.25.25h9.5a.25.25 0 00.25-.25V6h-2.75A1.75 1.75 0 019 4.25V1.5H3.75zm6.75.5v2.25c0 .138.112.25.25.25h2.25L10.5 2z"/></svg>
              <a href="/<%= owner %>/<%= repoName %>/blob/<%= currentBranch %>/<%= entry.name %>"><%= entry.name %></a>
            </div>
            <div class="file-tree-commit">
              <% const lc2 = lastCommits[entry.name]; if (lc2) { %>
              <span class="file-tree-commit-msg"><%= lc2.message.slice(0, 52) %><%= lc2.message.length > 52 ? '…' : '' %></span>
              <span class="file-tree-commit-date"><%= timeAgo(lc2.date) %></span>
              <% } %>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- Pages deployment banner -->
    <% if (hasPagesDeployment) { %>
    <div class="pages-banner">
      <div class="pages-banner-icon">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        <strong>Pages deployment active</strong> — <code>gh-pages</code> branch is live
      </div>
      <div class="pages-banner-links">
        <a href="<%= pagesHttpUrl %>" target="_blank" rel="noopener" class="pages-link">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M3.75 2h3.5a.75.75 0 010 1.5h-3.5a.25.25 0 00-.25.25v8.5c0 .138.112.25.25.25h8.5a.25.25 0 00.25-.25v-3.5a.75.75 0 011.5 0v3.5A1.75 1.75 0 0112.25 14h-8.5A1.75 1.75 0 012 12.25v-8.5C2 2.784 2.784 2 3.75 2zm6.854-1h4.146a.25.25 0 01.25.25v4.146a.25.25 0 01-.427.177L13.03 4.03 9.28 7.78a.75.75 0 01-1.06-1.06l3.75-3.75-1.543-1.543A.25.25 0 0110.604 1z"/></svg>
          HTTP
        </a>
        <a href="<%= pagesHttpsUrl %>" target="_blank" rel="noopener" class="pages-link pages-link-https">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M4 13H2v-2h2v2zm0-4H2V7h2v2zm0-4H2V3h2v2zm4 8H6v-2h2v2zm0-4H6V7h2v2zm0-4H6V3h2v2zm4 8h-2v-2h2v2zm0-4h-2V7h2v2zm0-4h-2V3h2v2zm2-3H2C.9 0 0 .9 0 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V2c0-1.1-.9-2-2-2z"/></svg>
          HTTPS <span class="pages-ssl-badge">SSL</span>
        </a>
      </div>
    </div>
    <% } %>

    <!-- README -->
    <% if (readme) { %>
    <div class="readme-box">
      <div class="readme-header">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M0 1.75A.75.75 0 01.75 1h4.253c1.227 0 2.317.59 3 1.501A3.744 3.744 0 0111.006 1h4.245a.75.75 0 01.75.75v10.5a.75.75 0 01-.75.75h-4.507a2.25 2.25 0 00-1.591.659l-.622.621a.75.75 0 01-1.062 0l-.622-.621A2.25 2.25 0 005.258 13H.75a.75.75 0 01-.75-.75V1.75zm7.25 10.32v-8.2a2.246 2.246 0 00-2.25-1.37H1.5v9h3.757a3.75 3.75 0 011.994.57zM8.75 12.07A3.75 3.75 0 0110.745 11.5H14.5v-9h-3.5a2.25 2.25 0 00-2.25 1.37v8.2z"/></svg>
        README
      </div>
      <div class="readme-body markdown-body"><%- readme %></div>
    </div>
    <% } %>

    <% } %>
  </div>
</main>
<%- include('../_foot') %>
<script>
const cloneBtn = document.getElementById('clone-btn');
const clonePopup = document.getElementById('clone-popup');
if (cloneBtn && clonePopup) {
  cloneBtn.addEventListener('click', e => { e.stopPropagation(); clonePopup.classList.toggle('open'); });
  document.addEventListener('click', () => clonePopup.classList.remove('open'));
}
function copyCloneUrl() {
  const inp = document.getElementById('clone-url-input');
  inp.select(); document.execCommand('copy');
}
</script>
