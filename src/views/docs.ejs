            <tr><td><span class="api-method method-get">GET</span></td><td><code>/api/repos/:owner/:repo/commits/:branch</code></td><td>No*</td><td>List commits (up to 50)</td></tr>
            <tr><td><span class="api-method method-get">GET</span></td><td><code>/api/repos/:owner/:repo/tree/:branch</code></td><td>No*</td><td>List directory contents</td></tr>
