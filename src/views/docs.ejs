            <tr><td><span class="api-method method-patch">PATCH</span></td><td><code>/api/repos/:owner/:repo</code></td><td>Owner</td><td>Update description, visibility</td></tr>
            <tr><td><span class="api-method method-delete">DELETE</span></td><td><code>/api/repos/:owner/:repo</code></td><td>Owner</td><td>Delete repository permanently</td></tr>
            <tr><td><span class="api-method method-post">POST</span></td><td><code>/api/repos/:owner/:repo/fork</code></td><td>Yes</td><td>Fork a repository</td></tr>
            <tr><td><span class="api-method method-post">POST</span></td><td><code>/api/repos/:owner/:repo/star</code></td><td>Yes</td><td>Star a repository</td></tr>
